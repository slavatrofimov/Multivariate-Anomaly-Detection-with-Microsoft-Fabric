            "name": "ImputeMode"
          },
          {
            "$type": "Float",
            "value": 0.9,
            "name": "MaxAnomalyRatio"
          },
          {
            "$type": "Integer",
            "value": 92,
            "name": "Periodicity"
          },
          {
            "$type": "Integer",
            "value": 0,
            "name": "Regularization"
          },
          {
            "$type": "Integer",
            "value": 45,
            "name": "Sensitivity"
          }
        ]
      },
      "detectionSettings": {
