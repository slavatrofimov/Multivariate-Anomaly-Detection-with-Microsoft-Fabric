      "fabricDataSource": {
        "dataSourceType": "KqlDb",
        "tableName": "ScadaTelemetry",
        "timestampColumnName": "timestamp",
        "instanceIDColumnName": "tag",
        "attributeColumnName": "value",
        "workspaceId": "00000000-0000-0000-0000-000000000000",
        "artifactId": "7e5f836f-fbd4-98a5-4b93-408b3d6c2c84"
      },
      "modelOption": {
        "modelSelection": {
          "modelAlgorithm": "SR_WINDOW",
          "modelVersion": "1.0",
          "modelName": "Spectral Residual with Window",
          "modelDescription": "Model has a good balance for different types of outliers. Uses Windowing Techinique."
        },
        "parameters": [
          {
            "$type": "String",
            "value": "daily",
            "name": "Granularity"
