  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "ScadaTelemetry\n| where timestamp between (_startTime .. _endTime) and tag in (_tags)\n| summarize value = avg(value) by tag, bin(timestamp, 10s)",
      "id": "37d00ab7-0532-4c5c-8b8f-0e0cb701e777",
      "usedVariables": [
        "_endTime",
        "_startTime",
        "_tags"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "AssetAnomaliesMVAD\n| where timestamp between (_startTime .. _endTime) and asset == _asset\n| project timestamp, severity",
      "id": "05c068cf-f518-448d-a74c-dcc26d1444e8",
      "usedVariables": [
        "_asset",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "AssetAnomaliesMVAD\n| where timestamp between (_startTime .. _endTime) and asset == _asset and is_anomaly\n| project-away is_anomaly",
      "id": "3491b681-2584-496a-811f-9f19f02b099c",
      "usedVariables": [
        "_asset",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "Assets\r\n| where AssetID  == _asset\r\n| project strcat(AssetID, \": \", AssetCode, \" - \", AssetType, \" (\", Manufacturer, \" - \", Model, \")\")",
      "id": "4c0ab9b1-5877-4709-bb27-98c6923c8d22",
      "usedVariables": [
        "_asset"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "Assets\n| where AssetID  == _asset\n| evaluate narrow()\n| project Attribute = Column, Value",
      "id": "33666ec8-1532-4404-988a-7e8fbb041fec",
      "usedVariables": [
        "_asset"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "Assets | project AssetID",
      "id": "632ff9e4-ce6c-47a7-99de-502b155ab3a3",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "05aa618a-2f27-44bd-b7a4-11bed8435454"
      },
      "text": "TagMetadata\n| where asset  == _asset\n| project tag, label = strcat(tag, ' (', metric, ')')\n| order by tag asc ",
      "id": "f592e200-eed8-43a0-baaa-2f83b6be5412",
      "usedVariables": [
        "_asset"
      ]
    }
  ]
}