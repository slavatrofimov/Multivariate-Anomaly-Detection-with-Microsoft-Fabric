.create-merge table ScadaTelemetry (tag:string, timestamp:datetime, value:real) 
.create-merge table AssetAnomaliesMVAD (is_anomaly:bool, asset:string, timestamp:datetime, score:real, severity:real, interpretation:dynamic) 
.create-merge table ScadaTelemetryRaw (metrics:dynamic, EventProcessedUtcTime:datetime, PartitionId:long, EventEnqueuedUtcTime:datetime) 
.create-merge table AssetAnomaliesMVADRaw (anomalies:dynamic, EventProcessedUtcTime:datetime, PartitionId:long, EventEnqueuedUtcTime:datetime) 
.create-merge table AssetAnomaliesMVADInterpretation (is_anomaly:bool, asset:string, timestamp:datetime, score:real, severity:real, tag:string, contribution_score:real, correlation_changes:dynamic) 
.create-merge table AssetMVADFeatures (tag:string, ordinal:int, asset:string) 
.create-merge table AssetMVADModels (asset:string, model_uri:string, sliding_window:long, effective_date:datetime) 
.create-merge table VehicleTelemetryRaw (event_id:guid, journey_id:string, vehicle_id:string, driver_id:string, event_category_id:int, timestamp:datetime, odometer:real, tire_pressure:dynamic, lat:real, lon:real, vehicle_speed:real, engine_rpm:real, transmission_gear_position:int, gear_lever_position:int, accelerator_pedal_position:real, brake_pedal_position:real, torque_at_transmission:real, engine_temp:real, transmission_temp:real, steering_wheel_angle:real, door_status:string, ignition_status:int, headlamp_status:int, high_beam_status:int, windshield_wiper_status:int, fuel_level:real, parking_brake_status:string) 
